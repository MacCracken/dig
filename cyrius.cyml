[package]
name = "dig"
version = "0.3.2"
description = "dig — DNS resolver (sovereign Cyrius reimplementation of BIND dig)"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.2.6"

[build]
entry = "src/main.cyr"
test = "src/test.cyr"
output = "dig"

[deps]
stdlib = ["string", "fmt", "alloc", "io", "vec", "str", "syscalls", "assert", "bench", "args", "flags"]
---
